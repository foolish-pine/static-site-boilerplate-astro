{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:best-practices"],
  "osvVulnerabilityAlerts": true,
  "prConcurrentLimit": 1,
  "prHourlyLimit": 0,
  "rebaseWhen": "never",
  "major": {
    "dependencyDashboardApproval": true
  },
  "packageRules": [
    {
      "groupName": "ESLint",
      "matchPackageNames": [
        "eslint",
        "@eslint/*",
        "eslint-*",
        "typescript-eslint"
      ]
    },
    {
      "groupName": "Prettier",
      "matchPackageNames": ["prettier", "prettier-*"]
    },
    {
      "groupName": "Stylelint",
      "matchPackageNames": ["stylelint", "stylelint-*"]
    }
  ]
}
